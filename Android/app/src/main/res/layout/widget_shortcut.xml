<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sw_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ECLIPSE"
        android:textColor="#5A5A6E"
        android:textStyle="bold"
        android:textSize="9sp"
        android:letterSpacing="0.28"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/sw_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LABEL"
        android:textColor="#C8F542"
        android:textStyle="bold"
        android:textSize="17sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        android:gravity="center"
        android:shadowColor="#30C8F542"
        android:shadowRadius="14"
        android:shadowDx="0"
        android:shadowDy="0"/>

    <TextView
        android:id="@+id/sw_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Abrir"
        android:textColor="#A0A0B0"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="8dp"/>
</LinearLayout>
